{# ==========================================================================
   基础 SVG 包装器 (Private Helper)
   - 统一管理 viewBox (默认 0 0 24 24)
   - 默认使用 currentColor 实现颜色跟随
   - 静态渲染，无动画
   ========================================================================== #}
{% macro _svg(path_d, size=24, class='', color=None, viewBox="0 0 24 24", type='fill', stroke_width=2) -%}
    <svg xmlns="http://www.w3.org/2000/svg" 
         viewBox="{{ viewBox }}" 
         width="{{ size }}" 
         height="{{ size }}" 
         class="{{ class }}"
         style="{{ 'fill' if type == 'fill' else 'stroke' }}: {{ color if color else 'currentColor' }}; 
                {{ 'fill: none;' if type == 'outline' else '' }}
                stroke-width: {{ stroke_width if type == 'outline' else 0 }};
                flex-shrink: 0; vertical-align: middle;">
        <path d="{{ path_d }}" 
              stroke-linecap="round" 
              stroke-linejoin="round"
        ></path>
    </svg>
{%- endmacro %}

{% macro _svg_duo(primary_d, secondary_d, size=24, class='', color=None) %}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="{{ size }}" height="{{ size }}" class="{{ class }}"
         style="fill: {{ color if color else 'currentColor' }}; flex-shrink: 0; vertical-align: middle;">
        <path d="{{ secondary_d }}" opacity="0.4"></path>
        <path d="{{ primary_d }}"></path>
    </svg>
{% endmacro %}

